#:kivy 2.2.0
#:import dp kivy.metrics.dp
#:import COLORS core.config.COLORS

<Label>:
    font_name: "Roboto"
    color: COLORS["text"]

<TextInput>:
    font_name: "Roboto"
    font_size: dp(15)
    foreground_color: COLORS["text"]
    background_color: COLORS["surface2"]
    cursor_color: COLORS["accent"]
    padding: [dp(12), dp(12), dp(12), dp(12)]
    multiline: False
    write_tab: False

<Spinner>:
    font_name: "Roboto"
    font_size: dp(14)
    background_normal: ""
    background_color: COLORS["surface2"]
    color: COLORS["text"]
    option_cls: "SpinnerOption"

<SpinnerOption>:
    font_name: "Roboto"
    font_size: dp(14)
    background_normal: ""
    background_color: COLORS["surface"]
    color: COLORS["text"]
    height: dp(44)
    size_hint_y: None

ScreenManager:
    SplashScreen:
    HomeScreen:

# ═══════════════════════════════════════════
# SPLASH SCREEN
# ═══════════════════════════════════════════
<SplashScreen>:
    name: "splash"
    canvas.before:
        Color:
            rgba: COLORS["bg"]
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: "vertical"
        padding: dp(40)
        spacing: dp(20)

        Widget:
            size_hint_y: 0.3

        Label:
            text: "📸"
            font_size: dp(64)
            size_hint_y: None
            height: dp(80)

        Label:
            text: "QC Teazzi"
            font_size: dp(28)
            bold: True
            color: COLORS["text"]
            size_hint_y: None
            height: dp(40)

        Label:
            text: "LGJA Edition"
            font_size: dp(14)
            color: COLORS["text_sec"]
            size_hint_y: None
            height: dp(24)

        Widget:
            size_hint_y: 0.15

        Label:
            id: splash_status
            text: "Memuat..."
            font_size: dp(14)
            color: COLORS["text_sec"]
            size_hint_y: None
            height: dp(24)

        ProgressBar:
            id: splash_progress
            max: 100
            value: 0
            size_hint_y: None
            height: dp(6)

        BoxLayout:
            id: splash_buttons
            orientation: "horizontal"
            spacing: dp(12)
            size_hint_y: None
            height: dp(48)
            opacity: 0
            disabled: True

            Button:
                id: btn_retry
                text: "Coba Lagi"
                font_size: dp(14)
                bold: True
                background_normal: ""
                background_color: COLORS["accent"]
                on_release: root.retry_download()

            Button:
                id: btn_skip
                text: "Lanjut Tanpa Template"
                font_size: dp(13)
                background_normal: ""
                background_color: COLORS["surface2"]
                on_release: root.skip_download()

        Widget:
            size_hint_y: 0.2


# ═══════════════════════════════════════════
# HOME SCREEN
# ═══════════════════════════════════════════
<HomeScreen>:
    name: "home"
    canvas.before:
        Color:
            rgba: COLORS["bg"]
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: "vertical"

        # ── HEADER ──
        BoxLayout:
            size_hint_y: None
            height: dp(56)
            padding: [dp(16), 0]
            canvas.before:
                Color:
                    rgba: COLORS["surface"]
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: "📸 QC Teazzi"
                font_size: dp(20)
                bold: True
                halign: "left"
                valign: "middle"
                text_size: self.size

        # ── SCROLL CONTENT ──
        ScrollView:
            do_scroll_x: False
            bar_color: COLORS["accent"]

            BoxLayout:
                orientation: "vertical"
                padding: dp(16)
                spacing: dp(12)
                size_hint_y: None
                height: self.minimum_height

                # NAMA PENGGUNA
                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(100)
                    padding: dp(14)
                    canvas.before:
                        Color:
                            rgba: COLORS["surface"]
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(12)]

                    Label:
                        text: "👤 Nama Pengguna"
                        font_size: dp(13)
                        color: COLORS["text_sec"]
                        halign: "left"
                        text_size: self.size
                        size_hint_y: None
                        height: dp(20)

                    TextInput:
                        id: inp_user
                        hint_text: "Ketik nama Anda"

                # INFO LOKASI
                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(170)
                    padding: dp(14)
                    spacing: dp(8)
                    canvas.before:
                        Color:
                            rgba: COLORS["surface"]
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(12)]

                    Label:
                        text: "📍 Informasi Lokasi QC"
                        font_size: dp(13)
                        color: COLORS["text_sec"]
                        halign: "left"
                        text_size: self.size
                        size_hint_y: None
                        height: dp(20)

                    TextInput:
                        id: inp_toko
                        hint_text: "Nama Toko (contoh: Batavia PIK)"

                    TextInput:
                        id: inp_tanggal
                        hint_text: "Tanggal QC (contoh: 10 Mar 26)"

                # TEMPLATE EXCEL
                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(170)
                    padding: dp(14)
                    spacing: dp(8)
                    canvas.before:
                        Color:
                            rgba: COLORS["surface"]
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(12)]

                    Label:
                        text: "📊 Template Excel"
                        font_size: dp(13)
                        color: COLORS["text_sec"]
                        halign: "left"
                        text_size: self.size
                        size_hint_y: None
                        height: dp(20)

                    Spinner:
                        id: dd_template
                        text: "Memuat..."
                        size_hint_y: None
                        height: dp(44)
                        on_text: root._on_template_selected(self.text)

                    Spinner:
                        id: dd_sheet
                        text: "Target Sheet"
                        size_hint_y: None
                        height: dp(44)

                # LAYOUT
                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(140)
                    padding: dp(14)
                    spacing: dp(8)
                    canvas.before:
                        Color:
                            rgba: COLORS["surface"]
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(12)]

                    Label:
                        text: "⚙️ Pengaturan Layout"
                        font_size: dp(13)
                        color: COLORS["text_sec"]
                        halign: "left"
                        text_size: self.size
                        size_hint_y: None
                        height: dp(20)

                    Spinner:
                        id: dd_layout
                        text: "LGJA"
                        size_hint_y: None
                        height: dp(44)
                        on_text: root._on_layout_selected(self.text)

                    Label:
                        id: lbl_layout_info
                        text: ""
                        font_size: dp(12)
                        color: COLORS["text_muted"]
                        size_hint_y: None
                        height: dp(20)

                # UPLOAD FOTO
                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(130)
                    padding: dp(14)
                    spacing: dp(8)
                    canvas.before:
                        Color:
                            rgba: COLORS["surface"]
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(12)]

                    Label:
                        text: "📸 Upload Foto QC"
                        font_size: dp(13)
                        color: COLORS["text_sec"]
                        halign: "left"
                        text_size: self.size
                        size_hint_y: None
                        height: dp(20)

                    Button:
                        text: "Pilih Foto dari Gallery"
                        font_size: dp(14)
                        bold: True
                        background_normal: ""
                        background_color: COLORS["accent"]
                        size_hint_y: None
                        height: dp(48)
                        on_release: root.pick_photos()

                    Label:
                        id: lbl_photo_count
                        text: "Belum ada foto dipilih"
                        font_size: dp(12)
                        color: COLORS["text_muted"]
                        size_hint_y: None
                        height: dp(20)

                # TOMBOL PROSES
                Button:
                    id: btn_process
                    text: "MULAI PROSES"
                    font_size: dp(16)
                    bold: True
                    background_normal: ""
                    background_color: COLORS["accent"]
                    size_hint_y: None
                    height: dp(56)
                    on_release: root.start_process()

                # PROGRESS
                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(60)
                    spacing: dp(6)

                    ProgressBar:
                        id: progress_bar
                        max: 100
                        value: 0
                        size_hint_y: None
                        height: dp(6)

                    Label:
                        id: lbl_status
                        text: ""
                        font_size: dp(13)
                        markup: True
                        color: COLORS["text_sec"]
                        size_hint_y: None
                        height: dp(24)

                # RESULT BOX (hidden initially)
                BoxLayout:
                    id: result_box
                    orientation: "vertical"
                    size_hint_y: None
                    height: dp(180)
                    padding: dp(14)
                    spacing: dp(10)
                    opacity: 0
                    disabled: True
                    canvas.before:
                        Color:
                            rgba: 0.063, 0.725, 0.506, 0.08
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(12)]

                    Label:
                        text: "✅ File Tersimpan"
                        font_size: dp(13)
                        color: COLORS["green"]
                        bold: True
                        size_hint_y: None
                        height: dp(20)

                    Label:
                        id: lbl_output_path
                        text: ""
                        font_size: dp(11)
                        color: COLORS["text_sec"]
                        size_hint_y: None
                        height: dp(18)

                    BoxLayout:
                        spacing: dp(8)
                        size_hint_y: None
                        height: dp(44)

                        Button:
                            text: "📤 Share"
                            font_size: dp(13)
                            bold: True
                            background_normal: ""
                            background_color: COLORS["accent"]
                            on_release: root.share_file()

                        Button:
                            text: "📂 Folder"
                            font_size: dp(13)
                            background_normal: ""
                            background_color: COLORS["surface2"]
                            on_release: root.open_folder()

                        Button:
                            text: "📊 Buka"
                            font_size: dp(13)
                            background_normal: ""
                            background_color: COLORS["surface2"]
                            on_release: root.open_file()

                    Widget:
                        size_hint_y: None
                        height: dp(4)

                # FOOTER
                Label:
                    text: "Build by AI & GJorma"
                    font_size: dp(11)
                    color: COLORS["text_muted"]
                    size_hint_y: None
                    height: dp(30)
